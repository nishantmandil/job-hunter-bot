# DevOps Job Hunter — Environment Variables
# These override anything in config.json

GROQ_API_KEY="" #GROQ API key for job search and company insights
GMAIL_ADDRESS="" #Gmail address for sending application emails
GMAIL_APP_PASSWORD="" #App password for Gmail (generate this in your Google Account settings for enhanced security)

# Optional (for email finding)
HUNTER_IO_KEY="" #Hunter.io API key for finding email addresses of hiring managers
APOLLO_IO_KEY="" #Apollo.io API key for finding email addresses and company insights
